# Local monorepo convenience env.
# Prefer app-specific files for deployment:
# - apps/api/.env.example
# - apps/web/.env.example

# App URLs and environment
NODE_ENV=development
LOG_LEVEL=debug
WEB_APP_URL=http://localhost:3000
API_APP_URL=http://localhost:4000
NEXT_PUBLIC_API_APP_URL=http://localhost:4000
API_PORT=4000

# PostgreSQL 16+ with PostGIS
DATABASE_URL=postgresql://neara:neara@localhost:5432/neara?schema=public

# Redis / BullMQ
REDIS_URL=redis://localhost:6379

# Admin sessions and CSRF
SESSION_SECRET=replace-with-a-long-random-secret
CSRF_SECRET=replace-with-a-different-long-random-secret
SESSION_COOKIE_NAME=neara.sid
CUSTOMER_SESSION_COOKIE_NAME=neara.customer.sid

# Mailtrap
MAILTRAP_HOST=sandbox.smtp.mailtrap.io
MAILTRAP_PORT=2525
MAILTRAP_USERNAME=
MAILTRAP_PASSWORD=
MAIL_FROM=no-reply@neara.local

# Google Maps / Places / Geocoding
GOOGLE_MAPS_API_KEY=

# S3-compatible object storage
S3_ENDPOINT=http://localhost:9000
S3_REGION=ap-south-1
S3_BUCKET=neara-local
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=http://localhost:9000/neara-local
UPLOAD_MAX_IMAGE_BYTES=5242880

# Rate limits
RATE_LIMIT_PUBLIC_SEARCH_PER_MINUTE=100
RATE_LIMIT_PUBLIC_SLOT_LOOKUP_PER_MINUTE=120
RATE_LIMIT_PUBLIC_BOOKING_CREATE_PER_MINUTE=20
RATE_LIMIT_PUBLIC_BOOKING_LOOKUP_PER_MINUTE=30
RATE_LIMIT_ADMIN_LOGIN_PER_WINDOW=10
RATE_LIMIT_PASSWORD_RESET_PER_HOUR=5
RATE_LIMIT_CUSTOMER_REGISTER_PER_MINUTE=10
RATE_LIMIT_CUSTOMER_LOGIN_PER_MINUTE=10
RATE_LIMIT_CUSTOMER_OTP_REQUEST_PER_HOUR=5
RATE_LIMIT_CUSTOMER_OTP_CONFIRM_PER_MINUTE=20
RATE_LIMIT_WINDOW_SECONDS=60
