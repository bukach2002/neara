generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TenantStatus {
  draft
  active
  inactive
  suspended
}

enum UserStatus {
  active
  inactive
  locked
}

enum PlatformRole {
  none
  platform_admin
}

enum TenantRole {
  owner
  admin
  staff
}

enum SessionAudience {
  admin
  customer
}

enum OtpPurpose {
  login
  password_reset
}

enum OtpChannel {
  email
  sms
  whatsapp
}

enum BookingStatus {
  confirmed
  cancelled
  completed
  no_show
}

enum AvailabilityExceptionType {
  block
  override
}

enum NotificationChannel {
  email
  whatsapp
}

enum NotificationStatus {
  queued
  sending
  sent
  failed
  permanently_failed
  skipped
}

enum UploadedAssetOwnerType {
  tenant
  expert
}

model User {
  id                    String               @id @default(uuid()) @db.Uuid
  email                 String?              @unique
  mobileNumber          String?              @unique
  name                  String
  passwordHash          String
  status                UserStatus           @default(active)
  platformRole          PlatformRole         @default(none)
  failedLoginAttempts   Int                  @default(0)
  lockedUntil           DateTime?
  passwordResetAt       DateTime?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  memberships           TenantMembership[]
  sessions              Session[]
  passwordResetTokens   PasswordResetToken[]
  otpTokens             OtpToken[]
  customerProfiles      Customer[]
  auditLogs             AuditLog[]           @relation("AuditActor")

  @@map("users")
}

model TenantMembership {
  id        String     @id @default(uuid()) @db.Uuid
  tenantId  String     @db.Uuid
  userId    String     @db.Uuid
  role      TenantRole
  createdAt DateTime   @default(now())
  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([userId])
  @@map("tenant_memberships")
}

model Session {
  id            String          @id @default(uuid()) @db.Uuid
  userId        String          @db.Uuid
  tokenHash     String          @unique
  audience      SessionAudience @default(admin)
  trustedDevice Boolean         @default(false)
  expiresAt     DateTime
  createdAt     DateTime        @default(now())
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([audience, expiresAt])
  @@map("sessions")
}

model OtpToken {
  id          String     @id @default(uuid()) @db.Uuid
  userId      String     @db.Uuid
  tokenHash   String     @unique
  purpose     OtpPurpose
  channel     OtpChannel
  recipient   String
  attempts    Int        @default(0)
  expiresAt   DateTime
  consumedAt  DateTime?
  createdAt   DateTime   @default(now())
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, purpose, channel, createdAt])
  @@index([expiresAt])
  @@map("otp_tokens")
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

model Category {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  slug        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenants     Tenant[]

  @@map("categories")
}

model Tenant {
  id               String             @id @default(uuid()) @db.Uuid
  name             String
  slug             String             @unique
  bookingPrefix    String             @unique
  status           TenantStatus       @default(draft)
  primaryCategoryId String?           @db.Uuid
  timezone         String?
  description      String?
  publicEmail      String?
  publicPhone      String?
  logoUrl          String?
  archivedAt       DateTime?
  activatedAt      DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  primaryCategory  Category?          @relation(fields: [primaryCategoryId], references: [id])
  memberships      TenantMembership[]
  locations        Location[]
  services         Service[]
  experts          Expert[]
  customers        Customer[]
  bookings         Booking[]
  notificationLogs NotificationLog[]
  auditLogs        AuditLog[]
  bookingAttempts  BookingAttemptLog[]
  uploadedAssets   UploadedAsset[]

  @@index([status])
  @@index([primaryCategoryId])
  @@map("tenants")
}

model Location {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @db.Uuid
  name        String
  addressLine String
  locality    String
  city        String
  state       String?
  postalCode  String?
  countryCode String    @default("IN")
  latitude    Decimal   @db.Decimal(9, 6)
  longitude   Decimal   @db.Decimal(9, 6)
  geo         Unsupported("geometry(Point,4326)")?
  isPrimary   Boolean   @default(true)
  isActive    Boolean   @default(true)
  archivedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bookings    Booking[]

  @@index([tenantId])
  @@index([locality])
  @@map("locations")
}

model Service {
  id                   String          @id @default(uuid()) @db.Uuid
  tenantId             String          @db.Uuid
  name                 String
  slug                 String
  description          String?
  durationMinutes      Int
  displayPriceAmount   Decimal?        @db.Decimal(10, 2)
  displayPriceCurrency String?         @default("INR")
  isActive             Boolean         @default(true)
  isPublic             Boolean         @default(true)
  bufferBeforeMinutes  Int?
  bufferAfterMinutes   Int?
  archivedAt           DateTime?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  tenant               Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  expertServices       ExpertService[]
  bookings             Booking[]

  @@unique([tenantId, name])
  @@unique([tenantId, slug])
  @@index([tenantId, isActive, isPublic])
  @@map("services")
}

model Expert {
  id                String                  @id @default(uuid()) @db.Uuid
  tenantId          String                  @db.Uuid
  displayName       String
  slug              String
  shortBio          String?
  photoUrl          String?
  phone             String?
  email             String?
  internalMetadata  Json?
  isActive          Boolean                 @default(true)
  archivedAt        DateTime?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  tenant            Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  expertServices    ExpertService[]
  availabilityRules AvailabilityRule[]
  exceptions        AvailabilityException[]
  bookings          Booking[]

  @@unique([tenantId, slug])
  @@index([tenantId, isActive])
  @@map("experts")
}

model ExpertService {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  expertId  String   @db.Uuid
  serviceId String   @db.Uuid
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  expert    Expert   @relation(fields: [expertId], references: [id], onDelete: Cascade)
  service   Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([expertId, serviceId])
  @@index([tenantId, isActive])
  @@map("expert_services")
}

model AvailabilityRule {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @db.Uuid
  expertId       String   @db.Uuid
  dayOfWeek      Int
  startLocalTime String
  endLocalTime   String
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  expert         Expert   @relation(fields: [expertId], references: [id], onDelete: Cascade)

  @@index([tenantId, expertId, dayOfWeek])
  @@map("availability_rules")
}

model AvailabilityException {
  id             String                    @id @default(uuid()) @db.Uuid
  tenantId       String                    @db.Uuid
  expertId       String                    @db.Uuid
  type           AvailabilityExceptionType
  startsOn       DateTime                  @db.Date
  endsOn         DateTime                  @db.Date
  startLocalTime String?
  endLocalTime   String?
  reason         String?
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt
  expert         Expert                    @relation(fields: [expertId], references: [id], onDelete: Cascade)

  @@index([tenantId, expertId, startsOn, endsOn])
  @@map("availability_exceptions")
}

model Customer {
  id        String    @id @default(uuid()) @db.Uuid
  tenantId  String    @db.Uuid
  userId    String?   @db.Uuid
  name      String
  phone     String?
  email     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  bookings  Booking[]

  @@index([tenantId, phone])
  @@index([userId])
  @@map("customers")
}

model Booking {
  id                         String        @id @default(uuid()) @db.Uuid
  bookingReference           String        @unique
  tenantId                   String        @db.Uuid
  locationId                 String        @db.Uuid
  serviceId                  String        @db.Uuid
  expertId                   String        @db.Uuid
  customerId                 String        @db.Uuid
  status                     BookingStatus @default(confirmed)
  startsAt                   DateTime
  endsAt                     DateTime
  timezone                   String
  displayTimeSnapshot        String
  tenantNameSnapshot         String
  locationNameSnapshot       String
  locationAddressSnapshot    String
  serviceNameSnapshot        String
  serviceDurationSnapshot    Int
  servicePriceSnapshot       Decimal?      @db.Decimal(10, 2)
  serviceCurrencySnapshot    String?
  expertDisplayNameSnapshot  String
  customerNameSnapshot       String
  customerPhoneSnapshot      String?
  customerEmailSnapshot      String?
  customerNote               String?       @db.VarChar(500)
  consentAcceptedAt          DateTime
  cancelledAt                DateTime?
  completedAt                DateTime?
  noShowAt                   DateTime?
  createdAt                  DateTime      @default(now())
  updatedAt                  DateTime      @updatedAt
  tenant                     Tenant        @relation(fields: [tenantId], references: [id])
  location                   Location      @relation(fields: [locationId], references: [id])
  service                    Service       @relation(fields: [serviceId], references: [id])
  expert                     Expert        @relation(fields: [expertId], references: [id])
  customer                   Customer      @relation(fields: [customerId], references: [id])

  @@unique([tenantId, expertId, startsAt, status])
  @@unique([tenantId, serviceId, expertId, startsAt, customerPhoneSnapshot, status])
  @@index([tenantId, startsAt])
  @@index([tenantId, bookingReference])
  @@map("bookings")
}

model NotificationLog {
  id              String              @id @default(uuid()) @db.Uuid
  tenantId        String?             @db.Uuid
  channel         NotificationChannel
  templateKey     String
  provider        String?
  status          NotificationStatus  @default(queued)
  recipientEmail  String?
  recipientPhone  String?
  payload         Json?
  errorMessage    String?
  attempts        Int                 @default(0)
  nextAttemptAt   DateTime?
  sentAt          DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  tenant          Tenant?             @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([status, nextAttemptAt])
  @@map("notification_logs")
}

model AuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String?  @db.Uuid
  actorUserId String?  @db.Uuid
  actorRole   String
  entityType  String
  entityId    String
  action      String
  summary     String
  before      Json?
  after       Json?
  sourceIp    String?
  createdAt   DateTime @default(now())
  tenant      Tenant?  @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  actor       User?    @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

model BookingAttemptLog {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String?  @db.Uuid
  serviceId     String?  @db.Uuid
  expertId      String?  @db.Uuid
  startsAt      DateTime?
  status        String
  reason        String
  customerName  String?
  customerPhone String?
  customerEmail String?
  customerNote  String?  @db.VarChar(500)
  sourceIp      String?
  createdAt     DateTime @default(now())
  tenant        Tenant?  @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@map("booking_attempt_logs")
}

model UploadedAsset {
  id          String                 @id @default(uuid()) @db.Uuid
  tenantId    String                 @db.Uuid
  ownerType   UploadedAssetOwnerType
  ownerId     String                 @db.Uuid
  key         String
  url         String
  mimeType    String
  sizeBytes   Int
  createdAt   DateTime               @default(now())
  tenant      Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, ownerType, ownerId])
  @@map("uploaded_assets")
}
